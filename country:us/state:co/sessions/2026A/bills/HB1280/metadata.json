{
  "legislative_session": "2026A",
  "identifier": "HB 1280",
  "title": "Sunset Regulation of Hemodialysis Treatment",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health Care & Health Insurance",
    "Professions & Occupations",
    "Public Health"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act implements the recommendation of the Colorado office of policy, research, and regulatory reform in the department of regulatory agencies in its sunset review and report by continuing the regulation of hemodialysis clinics and technicians for 11 years, until September 1, 2037.(Note: This summary applies to this bill as enacted.)"
    }
  ],
