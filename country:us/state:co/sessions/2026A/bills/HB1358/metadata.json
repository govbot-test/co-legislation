  "identifier": "HB 1358",
  "title": "Reduce Academic Accelerator Grant Program Appropriation",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act reduces by $5.2 million the appropriation for the Colorado academic accelerator grant program for the 2023-24 state fiscal year, which is available for expenditure through the 2026-27 state fiscal year.(Note: This summary applies to this bill as enacted.)"
    }
  ],
