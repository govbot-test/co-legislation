{
  "legislative_session": "2026A",
  "identifier": "SB 084",
  "title": "No Waiver for Legal Privileges State Auditor Documents",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act protects certain legal privileges for state entities related to disclosures to the state auditor, legislative audit committee, or governor for purposes of an investigation by the state auditor that is related to the state's fraud hotline.(Note: This summary applies to this bill as enacted.)"
    }
  ],
