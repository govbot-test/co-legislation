  "legislative_session": "2026A",
  "identifier": "HB 1377",
  "title": "Managed Care Entity Payments",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health Care & Health Insurance",
    "State Revenue & Budget"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act establishes that if a managed care entity receives federal funds or state money from the department of health care policy and financing and pays those funds or that money to the department of human services, the funds or money received by the department of human services is not included in the calculation of state fiscal year spending.(Note: This summary applies to this bill as enacted.)"
    }
  ],
