{
  "legislative_session": "2026A",
  "identifier": "HB 1323",
  "title": "Wildfire Resiliency Prohibiting Taking of Beavers",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Natural Resources & Environment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill prohibits the taking of beavers on public land for a recreational purpose or commerce in beaver fur, parts, or products. The parks and wildlife commission may adopt rules to implement the prohibition and, if the commission adopts rules, the rules must ensure that the role of beavers in the wildfire resiliency of public land is protected. A violation of the prohibition carries certain penalties.(Note: This summary applies to this bill as introduced.)"
    }
  ],
