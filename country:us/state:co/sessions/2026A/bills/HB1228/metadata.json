{
  "legislative_session": "2026A",
  "identifier": "HB 1228",
  "title": "Marriage & Family Therapy Clinical Requirements",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Professions & Occupations"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act allows an applicant for licensure as a marriage and family therapist (LMFT) whose master's or doctoral degree program did not include an internship or practicum to also be registered as an LMFT candidate but requires these candidates to complete an additional 700 supervised clinical hours to become an LMFT.(Note: This summary applies to this bill as enacted.)"
    }
  ],
