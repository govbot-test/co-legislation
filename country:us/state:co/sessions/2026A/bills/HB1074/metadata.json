  "abstracts": [
    {
      "note": "summary",
      "abstract": "The state constitution limits the number of days the general assembly may meet to no more than 120 calendar days for a regular session each year. The bill further limits the length of each regular session to no more than 90 consecutive calendar days each year.(Note: This summary applies to this bill as introduced.)"
    }
