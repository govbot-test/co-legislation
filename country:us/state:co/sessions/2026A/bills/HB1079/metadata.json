{
  "legislative_session": "2026A",
  "identifier": "HB 1079",
  "title": "Drive Motorcycle Written Permission",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children & Domestic Matters",
    "Transportation & Motor Vehicles"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act requires a minor who is under 18 years old to have written permission of the minor's parent or legal guardian to obtain an instruction permit to drive a motorcycle. The act does not apply to emancipated minors.(Note: This summary applies to this bill as enacted.)"
    }
  ],
