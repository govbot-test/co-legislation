{
  "legislative_session": "2026A",
  "identifier": "HB 1215",
  "title": "Technical Revision Online Marketplaces Requirement",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Business & Economic Development",
    "Financial Services & Commerce"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act makes a technical revision to language from Senate Bill 25-070, enacted in 2025, to clarify an online marketplace's obligation to alert law enforcement if the online marketplace knows or should have known that a third-party seller is selling or attempting to sell stolen goods to a consumer in Colorado.(Note: This summary applies to this bill as enacted.)"
    }
  ],
