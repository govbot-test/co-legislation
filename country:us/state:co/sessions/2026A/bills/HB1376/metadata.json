{
  "legislative_session": "2026A",
  "identifier": "HB 1376",
  "title": "Federal Adoption Money Cash Fund Updates",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children & Domestic Matters",
    "Human Services"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The excess federal Title IV-E reimbursements cash fund (cash fund) exists in current law and includes federal revenue in excess of the amount required to reimburse certain eligible foster care, prevention, and permanency services. The act renames the cash fund as the federal Title IV-E reimbursements cash fund and updates the permissible uses of the money in the cash fund to align with current federal requirements, which permit the state to apply savings associated with federal funding increases to a range of child welfare services. The act specifically authorizes the use of cash fund money for services to support a positive permanency outcome for a child or youth who might otherwise enter or reenter foster care.(Note: This summary applies to this bill as enacted.)"
    }
  ],
