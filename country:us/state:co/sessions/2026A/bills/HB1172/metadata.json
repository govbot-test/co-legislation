  "abstracts": [
    {
      "note": "summary",
      "abstract": "The 2025 general appropriations act is amended to balance and make adjustments to the total amount appropriated for capital construction projects. The cash funds portion of the appropriation is increased.\u00a0\u00a0\u00a0\u00a0\u00a0The 2024 general appropriations act is amended to balance and make adjustments to the total amount appropriated for capital construction projects. The cash funds portion of the appropriation is increased.(Note: This summary applies to this bill as enacted.)"
    }
  ],
