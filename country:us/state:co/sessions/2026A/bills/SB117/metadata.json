{
  "legislative_session": "2026A",
  "identifier": "SB 117",
  "title": "Permissible Methods of Selling Lottery Tickets",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Gaming, Lottery, & Racing"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act prohibits the Colorado lottery or any licensed lottery retailer from selling lottery tickets or instant scratch game tickets produced by the lottery for sale to the public on a credit basis.(Note: This summary applies to this bill as enacted.)"
    }
  ],
