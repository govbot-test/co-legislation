{
  "legislative_session": "2026A",
  "identifier": "HB 1029",
  "title": "Student Representation Commission on Higher Education",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Higher Education"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act expands the Colorado commission on higher education (commission) from 11 to 13 members by adding 2 nonvoting student members who are enrolled at a state-supported institution of higher education (student members). Specifically, the act adds:One student member from a graduate research university or a 4-year institution of higher education; andOne student member from a community college, local district college, or area technical college.\u00a0\u00a0\u00a0\u00a0\u00a0The governor shall make initial appointments of student members on or before July 1, 2027. Student members serve on the commission for a term of 2 years.\u00a0\u00a0\u00a0\u00a0\u00a0The act shrinks the advisory committee to the commission from 13 to 12 members by removing the advisory committee member designated to represent the students of the state.(Note: This summary applies to this bill as enacted.)"
    }
  ],
