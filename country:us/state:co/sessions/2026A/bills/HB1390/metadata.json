  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act eliminates the third-party evaluation requirement for the health disparities and community grant program (program) and instead requires the department of public health and environment to evaluate the effectiveness of the program.(Note: This summary applies to this bill as enacted.)"
    }
  ],
