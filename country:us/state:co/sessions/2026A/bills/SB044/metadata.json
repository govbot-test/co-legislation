  "legislative_session": "2026A",
  "identifier": "SB 044",
  "title": "Tax Collection Mineral Rights County Treasurers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fiscal Policy & Taxes"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill authorizes a board of county commissioners to cancel any taxes that have been levied on a severed mineral account 5 years after the date the taxes become delinquent. The bill establishes certain requirements for when a county may convey a tax lien on a severed mineral account to a grantee or surface owner of record after a period of 5 years.(Note: This summary applies to this bill as introduced.)"
    }
  ],
