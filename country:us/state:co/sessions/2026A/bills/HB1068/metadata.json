{
  "legislative_session": "2026A",
  "identifier": "HB 1068",
  "title": "Remote Participation Policies for Joint Committees",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "General Assembly"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The executive committee of the legislative council (executive committee) is authorized to adopt policies regarding the ability of members of the general assembly to remotely participate in interim committee meetings and in legislative proceedings during a disaster emergency. The act expands the executive committee's authority to adopt policies to allow remote participation in meetings of any joint committees comprised of members from both chambers that are held at any time of the year.(Note: This summary applies to this bill as enacted.)"
    }
  ],
