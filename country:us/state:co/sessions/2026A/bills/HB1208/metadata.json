  "legislative_session": "2026A",
  "identifier": "HB 1208",
  "title": "Sunset Compliance Advisory Panel Air Pollution",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Natural Resources & Environment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act continues the compliance advisory panel to the air pollution control division in the department of public health and environment for 10 years, until September 1, 2036, pursuant to the provisions of the sunset law.(Note: This summary applies to this bill as enacted.)"
    }
  ],
