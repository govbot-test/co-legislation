{
  "legislative_session": "2026A",
  "identifier": "HCR 1004",
  "title": "Person's Rights Related to Their Children",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children & Domestic Matters",
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The concurrent resolution submits a constitutional amendment to the voters of the state at the 2026 general election that adds to the nonexclusive list of inalienable rights of all persons the right to direct the upbringing, education, and care of their children.(Note: This summary applies to this concurrent resolution as introduced.)"
    }
  ],
