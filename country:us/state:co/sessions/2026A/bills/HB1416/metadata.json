{
  "legislative_session": "2026A",
  "identifier": "HB 1416",
  "title": "Transfers to General Fund & Colorado Economic Development Fund",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fiscal Policy & Taxes"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act requires the state treasurer to transfer $1.2 million from the universal high school scholarship cash fund (fund) to the Colorado economic development fund and $2.3 million from the fund to the general fund on June 30, 2026.(Note: This summary applies to this bill as enacted.)"
    }
  ],
