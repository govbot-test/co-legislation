{
  "legislative_session": "2026A",
  "identifier": "SB 121",
  "title": "Overtime Threshold for Agricultural Employees",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Labor & Employment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Beginning January 1, 2027, the act requires an agricultural employer to pay certain agricultural employees overtime pay for time worked in excess of 56 hours in a workweek. The act also increases penalties for an agricultural employer who commits wage theft and repeals the authority of the director of the division of labor standards and statistics to adopt rules concerning overtime pay for agricultural employees.(Note: This summary applies to this bill as enacted.)"
    }
  ],
