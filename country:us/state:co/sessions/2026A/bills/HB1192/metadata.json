{
  "legislative_session": "2026A",
  "identifier": "HB 1192",
  "title": "Homeless Prevention Activities Program Restructure",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Human Services"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act eliminates the homeless prevention activities program advisory committee and gives the division of housing within the department of local affairs the power to administer the homeless prevention activities program, to establish and enforce standards for all homeless prevention activities covered by the program, and to establish standards that assure program funds are properly allocated.(Note: This summary applies to this bill as enacted.)"
    }
  ],
