{
  "legislative_session": "2026A",
  "identifier": "HB 1381",
  "title": "Eliminate Cash Balance Requirement in Judicial Cash Fund",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Courts & Judicial"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act eliminates the requirement that the general assembly transfer sufficient funds to the commission on judicial discipline special cash fund (fund) so that the fund balance at the beginning of each fiscal year is at least $400,000. The act transfers $400,000 from the fund to the general fund.(Note: This summary applies to this bill as enacted.)"
    }
  ],
