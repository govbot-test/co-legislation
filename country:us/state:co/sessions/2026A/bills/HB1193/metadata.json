{
  "legislative_session": "2026A",
  "identifier": "HB 1193",
  "title": "Vision Tests for Pre-Kindergarten Students",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act requires that school districts test the vision of students in pre-kindergarten, in addition to testing the vision of students in kindergarten and the first, second, third, fifth, seventh, and ninth grades.\u00a0\u00a0\u00a0\u00a0\u00a0The act updates terminology by replacing the word 'sight' with the word 'vision'.(Note: This summary applies to this bill as enacted.)"
    }
  ],
