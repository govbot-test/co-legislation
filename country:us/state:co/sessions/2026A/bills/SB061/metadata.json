{
  "legislative_session": "2026A",
  "identifier": "SB 061",
  "title": "Publication Counties Without Legal Newspapers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Local Government",
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Current law requires a legal notice or advertisement (notice) to be published in a newspaper within the county in which the notice is required to be published that satisfies certain requirements, including a publication period requirement and a periodicals license with paid distribution (legal newspaper). If a legal newspaper does not exist in a county, the notice may be published using certain alternatives.\u00a0\u00a0\u00a0\u00a0\u00a0The act clarifies the order of priority of the type of newspaper in which the notice should be published. First, the notice should be published in a newspaper in the county that satisfies the requirements for publication and that has been published for at least one year. Second, the notice should be published in a newspaper in the county that would otherwise satisfy the requirements for publication but for the fact that it lacks a periodicals license, and that has been published for at least one year. Third, the notice should be published in a newspaper in the county even if it does not have a periodicals license or has not been published for at least one year. If there is no newspaper in the county or an adjoining county, notice may be published in a newspaper that satisfies the requirements for a legal newspaper chosen with primary consideration for geographic proximity.\u00a0\u00a0\u00a0\u00a0\u00a0Additionally, the act gives municipalities and special districts with territory in two counties permission to publish notice in a newspaper in either county, so long as the newspaper meets the legal requirements for publication.(Note: This summary applies to this bill as enacted.)"
    }
  ],
