  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act eliminates the requirement that the general assembly annually appropriate money to the department of public health and environment for the comprehensive human sexuality education grant program.(Note: This summary applies to this bill as enacted.)"
    }
