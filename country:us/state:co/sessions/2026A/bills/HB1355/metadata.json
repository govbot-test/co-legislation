{
  "legislative_session": "2026A",
  "identifier": "HB 1355",
  "title": "Reduce Appropriation Out-of-School Time Grant Program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act repeals the requirement for the general assembly to appropriate money in the 2026-27 state fiscal year for the out-of-school time program grant program (grant program).\u00a0\u00a0\u00a0\u00a0\u00a0The act reduces the appropriation for the 2026-27 state fiscal year to the department of education for use by the grant program by $1,750,000.(Note: This summary applies to this bill as enacted.)"
    }
  ],
