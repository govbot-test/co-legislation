  "abstracts": [
    {
      "note": "summary",
      "abstract": "Based on the findings and recommendations of the committee on legal services, the act extends all state agency rules that were adopted or amended on or after November 1, 2024, and before November 1, 2025.(Note: This summary applies to this bill as enacted.)"
    }
