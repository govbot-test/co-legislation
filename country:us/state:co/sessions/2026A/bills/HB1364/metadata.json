{
  "legislative_session": "2026A",
  "identifier": "HB 1364",
  "title": "2025 Consumer Price Index Calculation",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fiscal Policy & Taxes"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "For the purpose of calculating inflation based on the consumer price index for the 2025 calendar year, the act requires the index to be determined by averaging the 2 semiannual reports produced by the United States bureau of labor statistics for the 2025 calendar year.(Note: This summary applies to this bill as enacted.)"
    }
  ],
