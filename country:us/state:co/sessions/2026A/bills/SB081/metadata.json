  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill increases overtime protections for agricultural employees by requiring that agricultural employees be paid at an overtime rate for any work performed in excess of:40 hours per workweek;12 hours per workday; or12 consecutive hours.(Note: This summary applies to this bill as introduced.)"
    }
  ],
