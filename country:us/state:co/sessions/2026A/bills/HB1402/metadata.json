  ],
  "subject": [
    "Capital Construction",
    "State Government",
    "State Revenue & Budget"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act requires that the state treasurer make the following transfers of money on July 1, 2026:$131,514,555 from the general fund to the capital construction fund;$3,420,943 from the general fund to the information technology capital account in the capital construction fund;$500,000 from the general fund exempt account to the capital construction fund;$1,748,863 from the community impact cash fund to the information technology capital account in the capital construction fund;$587,318 from the motor carrier safety fund to the information technology capital account in the capital construction fund to be used for a records utilization upgrade for the Colorado state patrol; and$1,976,782 from the motorcycle operator safety training fund to the information technology capital account in the capital construction fund to be used for a records utilization upgrade for the Colorado state patrol.(Note: This summary applies to this bill as enacted.)"
    }
  ],
