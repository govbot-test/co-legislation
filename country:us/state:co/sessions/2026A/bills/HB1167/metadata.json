  "abstracts": [
    {
      "note": "summary",
      "abstract": "The 2025 general appropriations act is amended to balance and make adjustments to the total amount appropriated to the department of regulatory agencies. The general fund, reappropriated funds, and federal funds portions of the appropriation are increased and the cash funds portion is decreased.(Note: This summary applies to this bill as enacted.)"
    }
  ],
