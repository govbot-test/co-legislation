{
  "legislative_session": "2026A",
  "identifier": "HB 1085",
  "title": "Offer Pregnant Person Do Not Abort Form",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health Care & Health Insurance"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill requires a pregnant person's health-care provider to offer a pregnant person the option to fill out a \"Do Not Abort\" form that expresses the person's wishes to not receive an abortion in the event the person is incapacitated or incapable of communicating. If the pregnant person fills out a \"Do Not Abort\" form, the health-care provider shall input the form into the pregnant person's medical record.(Note: This summary applies to this bill as introduced.)"
    }
  ],
