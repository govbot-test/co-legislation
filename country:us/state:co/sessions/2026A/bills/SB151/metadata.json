{
  "legislative_session": "2026A",
  "identifier": "SB 151",
  "title": "Modify Public Employees Retirement Association Allowed Affiliation and Board of Trustees",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)",
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act adds Denver school of science and technology charter schools (DSST schools) in the Denver public schools division of the public employees' retirement association (PERA). The act also adds one voting member to the PERA board of trustees. The added member is to be elected from the Denver public schools division through a Denver public schools division election administered by PERA. The added member replaces a nonvoting ex officio board member from the Denver public schools division, whom the act removes from the board. The act permits PERA members who are employees of DSST schools to purchase service credit for their noncovered DSST employment prior to the act.(Note: This summary applies to this bill as enacted.)"
    }
  ],
