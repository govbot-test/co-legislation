  "legislative_session": "2026A",
  "identifier": "HB 1082",
  "title": "Children Are Not for Sale Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children & Domestic Matters",
    "Health Care & Health Insurance",
    "Professions & Occupations"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill adds trading anything of monetary value to buy or sell sexual activity with a minor who the person knows is being trafficked for sexual servitude as an act of human trafficking of a minor for sexual servitude. The bill changes the penalty of human trafficking of a minor for sexual servitude from a class 2 felony to a class 1 felony and requires the court to sentence a person convicted of the felony to life imprisonment without the possibility of parole.(Note: This summary applies to this bill as introduced.)"
    }
  ],
