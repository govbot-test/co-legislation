{
  "legislative_session": "2026A",
  "identifier": "HB 1293",
  "title": "Modernization of Requirements for Ballot Information Booklet",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Elections & Redistricting",
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act amends the statutory requirements for the ballot information booklet (booklet) to conform with modern drafting practices and to remove antiquated and redundant language from the booklet's required text. The act also repeals obsolete provisions regarding transfers to and from the ballot information publication and distribution revolving fund in state fiscal year 2007-08 through state fiscal year 2010-11.(Note: This summary applies to this bill as enacted.)"
    }
  ],
