  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill allows a person who is 72 years old or older to choose to temporarily or permanently opt out of jury service. The judge or jury commissioner may require documentation in support of the opt-out.(Note: This summary applies to this bill as introduced.)"
    }
  ],
