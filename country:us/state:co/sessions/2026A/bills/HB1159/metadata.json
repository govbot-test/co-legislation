  "abstracts": [
    {
      "note": "summary",
      "abstract": "The 2025 general appropriations act is amended to balance and make adjustments to the total amount appropriated to the department of labor and employment. The general fund and reappropriated funds portions of the appropriation are decreased and the cash funds and federal funds portions are increased.(Note: This summary applies to this bill as enacted.)"
    }
  ],
