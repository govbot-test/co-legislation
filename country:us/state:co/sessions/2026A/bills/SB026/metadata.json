{
  "legislative_session": "2026A",
  "identifier": "SB 026",
  "title": "Weight for Vehicles with Child Restraint System",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Transportation & Motor Vehicles"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act increases the gross vehicle weight rating limit from less than 10,000 pounds to less than 16,000 pounds for a passenger vehicle for which the use of a child restraint system is required.(Note: This summary applies to this bill as enacted.)"
    }
  ],
