  "identifier": "SB 179",
  "title": "Public Health Employee Whistleblower Rights",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Law",
    "Health Care & Health Insurance",
    "Public Health",
