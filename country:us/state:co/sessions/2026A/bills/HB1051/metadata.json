{
  "legislative_session": "2026A",
  "identifier": "HB 1051",
  "title": "Continue Microgrid Community Resilience Grant Program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Energy"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The microgrids for community resilience grant program (grant program) in the division of local government in the department of local affairs provides grants for cooperative electric associations and municipally owned utilities to purchase microgrid resources for eligible rural communities located within their service territories. Under current law, the grant program is set to repeal on September 1, 2026. The act continues the grant program indefinitely by removing the repeal date.(Note: This summary applies to this bill as enacted.)"
    }
  ],
