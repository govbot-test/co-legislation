{
  "legislative_session": "2026A",
  "identifier": "HB 1027",
  "title": "Board of Cooperative Services Definition & Executive Director",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act adds a board of cooperative services (BOCES) executive director to the list of individuals covered by the public employees' retirement association (PERA) who may be employed in specified education-related positions under certain circumstances with no change in their PERA retirement benefits.\u00a0\u00a0\u00a0\u00a0\u00a0The act permits local education providers to elect to have all or some of their postsecondary and workforce readiness start-up funding distribution made directly to a BOCES.(Note: This summary applies to this bill as enacted.)"
    }
  ],
