  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The 2025 general appropriations act is amended to balance and make adjustments to the total amount appropriated to the department of higher education. The general fund and reappropriated funds portions of the appropriation are decreased, and the cash funds and federal funds portions are increased.\u00a0\u00a0\u00a0\u00a0\u00a0The 2024 general appropriations act is amended to make adjustments to the amount appropriated to the department of higher education.(Note: This summary applies to this bill as enacted.)"
    }
  ],
