  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act allows the division of fire prevention and control to seek, accept, and expend gifts, grants, or donations to implement the requirements of the firefighter behavioral health benefits program.(Note: This summary applies to this bill as enacted.)"
