{
  "legislative_session": "2026A",
  "identifier": "HB 1260",
  "title": "Updates to Child Care Assistance Programs",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act extends the implementation dates for capping family copayments for child care at 7% of family income, for paying child care providers in advance of the provision of services, and for utilizing grants and contracts to improve access to child care for underserved populations to August 1, 2028.\u00a0\u00a0\u00a0\u00a0\u00a0The act modifies existing reporting requirements to include the total amount of child care assistance program (CCCAP) allocation that is spent by the department and each county on administrative expenses, county indirect expenses, program implementation costs, and direct service expenses.(Note: This summary applies to this bill as enacted.)"
    }
  ],
