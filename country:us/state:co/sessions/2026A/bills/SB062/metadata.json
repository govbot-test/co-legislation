{
  "legislative_session": "2026A",
  "identifier": "SB 062",
  "title": "Rodenticide Use Restrictions",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill prohibits a person from selling, distributing, applying, or using certain types of rodenticide and rodent glue traps in the state except as authorized for restricted and limited use in a public health emergency and in accordance with certain use requirements and time periods.\u00a0\u00a0\u00a0\u00a0\u00a0A person conducting professional rodent control services in the state is required to prioritize integrated pest management strategies, which involve implementing a combination of nonchemical rodent control measures. designates second-generation anticoagulant rodenticides, which are pesticides containing brodifacoum, bromadiolone, difenacoum, or difethialone as an active ingredient, as restricted-use pesticides and authorizes the commissioner of agriculture to restrict their distribution and use.(Note: Italicized words indicate new material added to the original summary; dashes through words indicate deletions from the original summary.)(Note: This summary applies to the reengrossed version of this bill as introduced in the second house.)"
    }
  ],
