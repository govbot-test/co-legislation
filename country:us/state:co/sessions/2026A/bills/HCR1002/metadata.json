  "abstracts": [
    {
      "note": "summary",
      "abstract": "The concurrent resolution amends the Colorado constitution to mandate that the general assembly require, by law, a person who distributes pornographic material to verify that each person who receives the material is 18 years old or older.(Note: This summary applies to this concurrent resolution as introduced.)"
    }
