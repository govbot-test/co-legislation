  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill gives the courts authority to make determinations for the care and custody of pet animals in proceedings for dissolution of marriage and legal separation. The bill permits a court to issue an emergency protection order concerning the custody and care of a pet animal.(Note: This summary applies to this bill as introduced.)"
    }
  ],
