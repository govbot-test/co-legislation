  "abstracts": [
    {
      "note": "summary",
      "abstract": "The 2025 general appropriations act is amended to balance and make adjustments to the total amount appropriated to the department of military and veterans affairs. The general fund and cash funds portions of the appropriation are increased and the federal funds portion is decreased.(Note: This summary applies to this bill as enacted.)"
    }
  ],
