{
  "legislative_session": "2026A",
  "identifier": "HB 1218",
  "title": "Clarifying Validity of Common Law Marriage",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Children & Domestic Matters"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Senate Bill 25-014, enacted in 2025, repealed a provision of law that stated certain marriage formality requirements do not invalidate an otherwise valid common law marriage. The act restores that provision to clarify the validity of common law marriage.(Note: This summary applies to this bill as enacted.)"
    }
  ],
