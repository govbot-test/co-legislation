{
  "legislative_session": "2026A",
  "identifier": "HB 1285",
  "title": "Admission to Mental Health Residential Facility",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crimes, Corrections, & Enforcement",
    "Human Services"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill requires the department of human services to include in the admission criteria for admitting a person to a mental health residential facility a prohibition on admitting a person who is required to register the person's residence in accordance with the \"Colorado Sex Offender Registration Act\" to a mental health residential facility that is located within 1,000 feet of a school.(Note: This summary applies to this bill as introduced.)"
    }
  ],
