  "identifier": "HB 1295",
  "title": "Repeal of Obsolete Statutory Requirements",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "General Assembly",
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act repeals reporting requirements that have already been fulfilled and do not contain a future repeal date. The act repeals duties related to repealed reports and repeals task forces, working groups, and review counsels created to make outdated reports.(Note: This summary applies to this bill as enacted.)"
    }
  ],
