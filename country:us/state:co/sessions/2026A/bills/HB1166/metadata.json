  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The 2025 general appropriations act is amended to balance and make adjustments to the total amount appropriated to the department of public safety. The general fund, cash funds, and reappropriated funds portions of the appropriation are increased and the federal funds portions is decreased.(Note: This summary applies to this bill as enacted.)"
    }
  ],
