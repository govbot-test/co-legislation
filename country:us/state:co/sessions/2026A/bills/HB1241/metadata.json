{
  "legislative_session": "2026A",
  "identifier": "HB 1241",
  "title": "Carrier to Notify Provider Material Change Contract",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Insurance"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "In current law concerning contracts with health-care providers, an entity wishing to make a material change to such a contract must provide written notice of the change to the health-care provider at least 90 days before the effective date of the change. The bill adds language requiring a person to give such written notice by registered mail and by email to the health-care provider or administrator who signed the contract and adds a reference to this language in the area of the Colorado Revised Statutes concerning health-care insurance carriers.(Note: This summary applies to this bill as introduced.)"
    }
  ],
