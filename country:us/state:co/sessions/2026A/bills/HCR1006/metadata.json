{
  "legislative_session": "2026A",
  "identifier": "HCR 1006",
  "title": "Governor Proclamation Respect Separation of Powers",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "General Assembly",
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "If approved by at least 55% of the voters of the state voting on the issue at the 2026 general election, the concurrent resolution amends the Colorado constitution to require, when a governor convenes the general assembly by proclamation, that the business specially named in the proclamation must not be so narrowly framed as to impose a particular outcome on the general assembly.(Note: This summary applies to this concurrent resolution as introduced.)"
    }
  ],
