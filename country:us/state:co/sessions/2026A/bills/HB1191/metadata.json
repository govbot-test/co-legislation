{
  "legislative_session": "2026A",
  "identifier": "HB 1191",
  "title": "Examination of School District Records",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education & School Finance (Pre & K-12)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act authorizes the state auditor, in the state auditor's discretion, to audit the records of a school district that received state education fund money (school district) for capital construction projects for qualified charter schools in the district to determine the amount of state education fund money expended by each school district in the state for capital construction and to identify the schools and projects on which school districts expended the money.(Note: This summary applies to this bill as enacted.)"
    }
  ],
