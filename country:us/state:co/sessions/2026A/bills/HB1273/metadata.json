{
  "legislative_session": "2026A",
  "identifier": "HB 1273",
  "title": "Transportation Network Company Maximum Percent Fare Retention",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Labor & Employment",
    "Transportation & Motor Vehicles"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The bill prohibits a transportation network company (TNC) from retaining more than 20% of a consumer fare paid for a driver's completion of a transportation task through the TNC's digital platform. \"Consumer fare\" is defined in the bill as the amount a consumer pays for a transportation task, excluding tips and pass-throughs such as payments for tolls. A TNC is also not allowed to impose a fee on a TNC driver unless the amount of the fee plus the amount that the TNC retains from a consumer fare does not exceed 20% of the consumer fare.(Note: This summary applies to this bill as introduced.)"
    }
  ],
