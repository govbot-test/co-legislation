{
  "legislative_session": "2026A",
  "identifier": "SB 128",
  "title": "Sales & Use Tax Destination Management Company",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fiscal Policy & Taxes"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act exempts the sale, storage, use, or consumption of tangible personal property, commodities, or services sold by a destination management company from state sales and use taxation, beginning July 1, 2027. The exemption only applies if the destination management company has already paid the state the applicable sales or use tax on the property, commodities, or services upon acquisition.(Note: This summary applies to this bill as enacted.)"
    }
  ],
