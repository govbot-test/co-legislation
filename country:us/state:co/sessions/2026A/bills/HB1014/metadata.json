{
  "legislative_session": "2026A",
  "identifier": "HB 1014",
  "title": "Extend Colorado Job Growth Incentive Tax Credit",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "State Government"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Under current law, the Colorado job growth incentive tax credit (credit) may only be allowed by the economic development commission (commission) through state income tax year 2026. The act amends the Colorado job growth incentive tax credit to authorize the commission to allow new credit awards through state income tax year 2034. The act also extends the commission's annual reporting requirement through September 1, 2042.(Note: This summary applies to this bill as enacted.)"
    }
  ],
