{
  "legislative_session": "2026A",
  "identifier": "SB 016",
  "title": "Prohibit Discharge Preproduction Plastic Materials",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Natural Resources & Environment",
    "Public Health",
    "Water"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act prohibits the discharge of plastic pellets and other preproduction plastic materials through land application or into state waters, wastewater, storm water runoff, or other runoff by a facility that makes, uses, packages, or transports plastic pellets or other preproduction plastic materials in the state.(Note: This summary applies to this bill as enacted.)"
    }
  ],
