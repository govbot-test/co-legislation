{
  "legislative_session": "2026A",
  "identifier": "HB 1230",
  "title": "Extend Conservation Easement Tax Credit",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fiscal Policy & Taxes"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Under current law, the conservation easement tax credit (credit) may be claimed through state income tax year 2031. The bill amends the credit to allow taxpayers to claim the credit through state income tax year 2036. (Note: This summary applies to this bill as introduced.)"
    }
  ],
