{
  "legislative_session": "2026A",
  "identifier": "HB 1034",
  "title": "Modifications to Standards for Irrigation Equipment",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Water"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "In 2023, the general assembly established water and energy efficiency standards for irrigation controllers and spray sprinkler bodies that are sold or leased in the state on and after January 1, 2026. The act repeals these standards.(Note: This summary applies to this bill as enacted.)"
    }
  ],
