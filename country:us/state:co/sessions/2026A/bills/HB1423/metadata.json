{
  "legislative_session": "2026A",
  "identifier": "HB 1423",
  "title": "Community Corrections Budget Request & Data Information",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crimes, Corrections, & Enforcement"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Beginning in state fiscal year 2027-28, the act requires the department of public safety (department) to submit a budget request for community corrections and to include in its budget request information regarding projected community corrections program needs, including certain data points and analysis related to residential and nonresidential bed capacity, the per diem reimbursement rate for each bed type, and other guideposts related to community corrections appropriations.\u00a0\u00a0\u00a0\u00a0\u00a0The department must include information on the budget request in its yearly 'SMART Act' hearing.(Note: This summary applies to this bill as enacted.)"
    }
  ],
