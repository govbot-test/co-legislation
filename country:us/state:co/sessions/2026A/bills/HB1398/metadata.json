{
  "legislative_session": "2026A",
  "identifier": "HB 1398",
  "title": "Retail Delivery Fee Revenue Allocation",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fiscal Policy & Taxes",
    "Transportation & Motor Vehicles"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Under current law, 28.9% of the revenue the state collects from the retail delivery fee is credited to the multimodal transportation and mitigation options fund (fund). Of the money from the retail delivery fee that is credited to the fund, currently 85% is allocated to the commission for local multimodal projects and 15% is allocated to the commission for state multimodal projects. Beginning on July 1, 2026, the act changes how the fund allocates and expends retail delivery fee revenue between state and local multimodal projects so that 70% of the fund is allocated to the commission for local multimodal projects and 30% of the fund is allocated to the commission for state multimodal projects.(Note: This summary applies to this bill as enacted.)"
    }
  ],
